<Window x:Class="OrangMSS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrangMSS"
        mc:Ignorable="d"
        Title="OrangMSS - Store Installer" Height="400" Width="450"
        Background="#FF1E1E1E" Foreground="White"
        Icon="orange.ico">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF333333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FF555555" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF444444" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF222222" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FF2B2B2B" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF444444" />
                                <Setter Property="Foreground" Value="#FF888888" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Button x:Name="InstallButton" Content="Install Microsoft Store" Background="Orange" Foreground="Black" Width="200" Height="36" Click="InstallButton_Click" />
            <Button x:Name="UninstallButton" Content="Uninstall Store" Background="#FFCC3333" Foreground="White" Width="100" Height="36" Click="UninstallButton_Click" Margin="10,0,0,0"/>
            <Button x:Name="CancelButton" Content="Cancel" Background="#FF333333" Foreground="White" Width="90" Height="36" Click="CancelButton_Click" IsEnabled="False" Margin="10,0,0,0"/>
        </StackPanel>
        <ProgressBar x:Name="ProgressBar" Grid.Row="1" Height="20" Margin="0,10,0,10" Minimum="0" Maximum="100" Background="#FF2D2D2D" Foreground="Orange" BorderBrush="#FF444444" />
        <TextBox x:Name="LogTextBox" Grid.Row="2" Background="#FF252526" Foreground="White" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" />
    </Grid>
</Window>